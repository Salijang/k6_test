# Copy this file to a local shell env file and source it before running k6.
# Do not commit real tokens.

export K6_BASE_URL="https://api.sallijang.shop"
# export K6_BASE_URL_PRODUCT="https://product-api.sallijang.shop"
# export K6_BASE_URL_ORDER="https://order-api.sallijang.shop"

export K6_STORE_ID="1"
export K6_STORE_NAME="Stress Test Store"

# Auth, if the target environment requires it.
# Product write/delete and order APIs read JWT from the access_token cookie.
# Use a seller token for product setup/cleanup, and one or more buyer tokens for order traffic.
# Generic K6_ACCESS_TOKEN is a fallback for simple smoke tests.
# export K6_ACCESS_TOKEN=""
# export K6_ACCESS_TOKENS=""
# export K6_SELLER_ACCESS_TOKEN=""
# export K6_BUYER_ACCESS_TOKEN=""
# export K6_BUYER_ACCESS_TOKENS=""
# export K6_AUTH_TOKEN=""
# export K6_AUTH_HEADER_NAME="x-user-id"
# export K6_AUTH_HEADER_VALUE=""

export K6_GEO_CENTER_LAT="37.5665"
export K6_GEO_CENTER_LNG="126.9780"
export K6_GEO_RADIUS="0.1"
export K6_PRODUCT_CATEGORIES="베이커리,과일,채소,반찬,한식,분식"

# Conservative dev defaults.
export K6_READ_RATE="5"
export K6_READ_DURATION="1m"
export K6_ORDER_RATE="2"
export K6_ORDER_DURATION="1m"

export K6_PRODUCT_POOL_SIZE="10"
export K6_PRODUCT_REMAINING_INIT="100000"
export K6_ITEM_QUANTITY="1"
export K6_UNIT_PRICE="8000"
export K6_PAYMENT_METHOD="toss"
export K6_PICKUP_EXPECTED_AT="18:00"

# Product list load defaults.
export K6_READ_P95_THRESHOLD="800"

# Step-load for capacity/HPA observation.
export K6_STEP_TARGETS="5,10,20,40,80"
export K6_STEP_RAMP_DURATION="30s"
export K6_STEP_HOLD_DURATION="2m"
export K6_STEP_COOLDOWN_DURATION="30s"
# Keep this off for exploratory capacity runs. Turn on for regression gates.
export K6_ENFORCE_THRESHOLDS="0"

# Spike test defaults.
export K6_SPIKE_BASE_RATE="5"
export K6_SPIKE_RATE="50"
export K6_SPIKE_P95_THRESHOLD="1500"

# Soak test defaults.
export K6_SOAK_VUS="5"
export K6_SOAK_DURATION="30m"
export K6_SOAK_ORDER_PROBABILITY="0.2"
export K6_THINK_TIME_SECONDS="1"

# Optional suite switches.
export K6_RUN_ORDER_LOAD="0"
export K6_RUN_STEP_LOAD="0"
export K6_RUN_SPIKE="0"
export K6_RUN_SOAK="0"

# Optional health endpoints, if services expose them.
# export K6_PRODUCT_HEALTH_PATH="/health"
# export K6_ORDER_HEALTH_PATH="/health"
